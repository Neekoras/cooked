{
  "manifest_version": 3,
  "name": "Cooked",
  "version": "1.0.0",
  "description": "Am I cooked? Instant grade math for Canvas.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://*.instructure.com/*",
    "https://sequoia.instructure.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://*.instructure.com/courses/*/grades*",
        "https://sequoia.instructure.com/courses/*/grades*"
      ],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Cooked"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
