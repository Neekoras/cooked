{
  "manifest_version": 3,
  "name": "Cooked",
  "version": "1.1.0",
  "description": "Am I cooked? Instant grade math for Canvas.",
  "permissions": ["storage", "sidePanel", "tabs"],
  "host_permissions": [
    "https://*.instructure.com/*"
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Cooked"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
